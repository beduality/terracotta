<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div x-data="deploymentsApp()" x-cloak class="md-typeset">

  <div class="mdx-filters">
    <div class="mdx-search-row">
      <div class="mdx-search">
        <input type="text" x-model="search" placeholder="Search deployments…" class="mdx-search__input" autocapitalize="off" autocorrect="off" autocomplete="off" spellcheck="false" />
        <span class="mdx-search__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="1.2rem" height="1.2rem"><path fill="currentColor" d="M9.5 3A6.5 6.5 0 0 1 16 9.5c0 1.61-.59 3.09-1.56 4.23l.27.27h.79l5 5-1.5 1.5-5-5v-.79l-.27-.27A6.5 6.5 0 0 1 9.5 16 6.5 6.5 0 0 1 3 9.5 6.5 6.5 0 0 1 9.5 3m0 2A4.5 4.5 0 0 0 5 9.5 4.5 4.5 0 0 0 9.5 14 4.5 4.5 0 0 0 14 9.5 4.5 4.5 0 0 0 9.5 5Z"/></svg>
        </span>
        <button x-show="search" @click="search = ''" class="mdx-search__clear" aria-label="Clear search">
          <svg viewBox="0 0 24 24" width="1rem" height="1rem"><path fill="currentColor" d="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"/></svg>
        </button>
      </div>
      <button class="mdx-filter-btn" @click="showAdvanced = true" :class="{ 'mdx-filter-btn--active': hasAdvancedFilters }" title="Advanced filters">
        <svg viewBox="0 0 24 24" width="1.1rem" height="1.1rem"><path fill="currentColor" d="M14 12V19.88C14.04 20.18 13.94 20.5 13.71 20.71C13.32 21.1 12.69 21.1 12.3 20.71L10.29 18.7C10.06 18.47 9.96 18.16 10 17.87V12H9.97L4.21 4.62C3.87 4.19 3.95 3.56 4.38 3.22C4.57 3.08 4.78 3 5 3V3H19V3C19.22 3 19.43 3.08 19.62 3.22C20.05 3.56 20.13 4.19 19.79 4.62L14.03 12H14Z"/></svg>
      </button>
    </div>

    <nav class="md-tags mdx-module-tags">
      <span class="md-tag" :class="!moduleFilter ? 'md-tag--ins' : ''" @click="moduleFilter = ''" style="cursor:pointer;">All</span>
      {% for id, label, icon in all_modules %}
      <span class="md-tag" :class="moduleFilter === '{{ id }}' ? 'md-tag--ins' : ''" @click="moduleFilter = moduleFilter === '{{ id }}' ? '' : '{{ id }}'" style="cursor:pointer;">
        {% if id in module_icons %}<span class="mdx-tag-icon twemoji"><svg viewBox="{{ module_icons[id].viewBox }}" width=".9rem" height=".9rem" fill="currentColor">{{ module_icons[id].inner|safe }}</svg></span>{% endif %}
        {{ label }}
      </span>
      {% endfor %}
    </nav>
  </div>

  <div class="mdx-modal-backdrop" x-show="showAdvanced" @click.self="showAdvanced = false" x-transition.opacity>
    <div class="mdx-modal" @keydown.escape.window="showAdvanced = false">
      <div class="mdx-modal__header">
        <h2>Advanced filters</h2>
        <button class="mdx-modal__close" @click="showAdvanced = false" aria-label="Close">
          <svg viewBox="0 0 24 24" width="1.2rem" height="1.2rem"><path fill="currentColor" d="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"/></svg>
        </button>
      </div>
      <div class="mdx-modal__body">
        <div class="mdx-modal__col">
          <div class="mdx-field">
            <label class="mdx-field__label">From date</label>
            <input type="date" x-model="dateFrom" class="mdx-field__input" />
          </div>
          <div class="mdx-field">
            <label class="mdx-field__label">From version</label>
            <select x-model="versionFrom" class="mdx-field__input">
              <option value="">Any</option>
              <template x-for="v in versions" :key="v">
                <option :value="v" x-text="'v'+v"></option>
              </template>
            </select>
          </div>
        </div>
        <div class="mdx-modal__col">
          <div class="mdx-field">
            <label class="mdx-field__label">To date</label>
            <input type="date" x-model="dateTo" class="mdx-field__input" />
          </div>
          <div class="mdx-field">
            <label class="mdx-field__label">To version</label>
            <select x-model="versionTo" class="mdx-field__input">
              <option value="">Any</option>
              <template x-for="v in versions" :key="v">
                <option :value="v" x-text="'v'+v"></option>
              </template>
            </select>
          </div>
        </div>
        <label class="mdx-checkbox">
          <input type="checkbox" x-model="releasesOnly" /> Releases only
        </label>
      </div>
      <div class="mdx-modal__footer">
        <button class="md-button" @click="clearAdvanced()">Clear</button>
        <button class="md-button md-button--primary" @click="showAdvanced = false">Apply</button>
      </div>
    </div>
  </div>

  <template x-for="d in displayed" :key="d.version">
    <div class="mdx-deployment">
      <div class="mdx-deployment-header">
        <span class="mdx-title" x-text="d.title"></span>
        <a class="mdx-version"
           :href="'https://github.com/beduality/terracotta/releases/tag/v'+d.version"
           x-text="'v'+d.version"></a>
        <span x-show="d.isRelease" class="mdx-release">Release</span>
        <span class="mdx-date"><svg class="mdx-date-icon" viewBox="0 0 24 24" width=".75rem" height=".75rem" fill="currentColor"><path d="M12 2A10 10 0 0 0 2 12A10 10 0 0 0 12 22A10 10 0 0 0 22 12A10 10 0 0 0 12 2M12 4A8 8 0 0 1 20 12A8 8 0 0 1 12 20A8 8 0 0 1 4 12A8 8 0 0 1 12 4M12.5 7H11V13L16.25 16.15L17 14.92L12.5 12.25V7Z"/></svg><span x-text="fmtDate(d.createdAt)"></span></span>
      </div>
      <p class="mdx-summary" x-text="d.summary"></p>
      <div class="mdx-links" x-show="d.modules && d.modules.length > 0">
        <a x-show="d.modules && d.modules.includes('modrinth')"
           class="mdx-link" :title="moduleLabel('modrinth')"
           :href="'https://modrinth.com/plugin/terracotta/version/'+d.version"><span class="mdx-tag-icon twemoji" x-html="moduleIcon('modrinth')"></span></a>
        <a x-show="d.modules && d.modules.includes('hangar')"
           class="mdx-link" :title="moduleLabel('hangar')"
           :href="'https://hangar.papermc.io/beduality/Terracotta/versions/'+d.version"><span class="mdx-tag-icon twemoji" x-html="moduleIcon('hangar')"></span></a>
        <template x-for="m in (d.modules||[]).filter(x=>x!=='modrinth'&&x!=='hangar')" :key="m">
          <span class="mdx-link-wrap">
            <a x-show="moduleLink(m, d.version)" class="mdx-link" :title="moduleLabel(m)" :href="moduleLink(m, d.version)"><span class="mdx-tag-icon twemoji" x-html="moduleIcon(m)"></span></a>
            <span x-show="!moduleLink(m, d.version)" class="mdx-link" :title="moduleLabel(m)"><span class="mdx-tag-icon twemoji" x-html="moduleIcon(m)"></span></span>
          </span>
        </template>
      </div>
    </div>
  </template>

  <div x-show="filtered.length > limit" class="mdx-show-more">
    <button class="md-button md-button--primary" @click="all = !all"
      x-text="all ? 'Show last '+limit+' only' : 'Show all '+filtered.length+' deployments'"></button>
  </div>

  <p x-show="filtered.length === 0" class="mdx-empty">
    No deployments match the current filters.
  </p>

</div>

<script>
function deploymentsApp() {
  return {
    data: {{ deployments_json|safe }},
    moduleLabels: {{ module_labels|tojson }},
    moduleIcons: {{ module_icons_json|safe }},
    search: '', moduleFilter: '', dateFrom: '', dateTo: '',
    versionFrom: '', versionTo: '', releasesOnly: false,
    all: false, limit: 10, showAdvanced: false,

    get versions() {
      return [...new Set(this.data.map(d => d.version))].sort(this.cmp.bind(this));
    },

    get hasAdvancedFilters() {
      return !!(this.dateFrom || this.dateTo || this.versionFrom || this.versionTo || this.releasesOnly);
    },

    clearAdvanced() {
      this.dateFrom = '';
      this.dateTo = '';
      this.versionFrom = '';
      this.versionTo = '';
      this.releasesOnly = false;
    },

    moduleLabel(id) {
      return this.moduleLabels[id] || id.replace(/-/g, ' ');
    },

    moduleIcon(id) {
      const ic = this.moduleIcons[id];
      if (!ic) return '';
      return '<svg viewBox="' + ic.viewBox + '" width=".8rem" height=".8rem" fill="currentColor" style="vertical-align:middle;margin-right:.2rem;opacity:.7">' + ic.inner + '</svg>';
    },

    moduleLink(id, version) {
      const mavenModules = ['core', 'gradle-plugin'];
      if (mavenModules.includes(id)) {
        const artifact = id === 'core' ? 'terracotta-core' : 'terracotta-gradle-plugin';
        return 'https://central.sonatype.com/artifact/io.github.beduality/' + artifact + '/' + version;
      }
      return '';
    },

    get filtered() {
      return this.data.filter(d => {
        if (this.search) {
          const h = (d.title + ' ' + d.summary + ' ' + d.version + ' ' + d.createdAt).toLowerCase();
          if (!h.includes(this.search.toLowerCase())) return false;
        }
        if (this.moduleFilter && !(d.modules || []).includes(this.moduleFilter)) return false;
        if (this.dateFrom && d.createdAt < this.dateFrom) return false;
        if (this.dateTo && d.createdAt > this.dateTo) return false;
        if (this.versionFrom && this.cmp(d.version, this.versionFrom) < 0) return false;
        if (this.versionTo && this.cmp(d.version, this.versionTo) > 0) return false;
        if (this.releasesOnly && !d.isRelease) return false;
        return true;
      });
    },

    get displayed() {
      const n = this.all ? this.filtered.length : Math.min(this.limit, this.filtered.length);
      return this.filtered.slice(0, n);
    },

    cmp(a, b) {
      const pa = a.split('.').map(Number), pb = b.split('.').map(Number);
      for (let i = 0; i < Math.max(pa.length, pb.length); i++) {
        if ((pa[i] || 0) < (pb[i] || 0)) return -1;
        if ((pa[i] || 0) > (pb[i] || 0)) return 1;
      }
      return 0;
    },

    fmtDate(s) {
      const d = new Date(s);
      if (isNaN(d)) return s;
      const p = n => String(n).padStart(2, '0');
      let h = d.getUTCHours();
      const ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      return `${p(d.getUTCMonth()+1)}-${p(d.getUTCDate())}-${d.getUTCFullYear()} ${h}:${p(d.getUTCMinutes())} ${ampm}`;
    }
  };
}
</script>
