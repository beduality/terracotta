{
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        ".gitignore": ".gitattributes",
        "settings.gradle.kts": "gradle.properties, gradlew, gradlew.bat",
        "build.gradle.kts": "settings.gradle, jitpack.yml",
        "README.md": "CONTRIBUTING.md, CHANGELOG.md, LICENSE, SECURITY.md",
        "pyproject.toml": ".python-version, uv.lock, .coverage",
        ".env.example": ".env"
    },
    "files.exclude": {
        "**/.venv": true,
        "**/.gradle": true,
        "**/site": true,
        "gradle/**": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.kotlin": true
    }
}