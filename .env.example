# Modrinth API Token
# Get from: https://modrinth.com/settings/api
MODRINTH_TOKEN=your_modrinth_api_token

# OSSRH (OSS Sonatype) Credentials for publishing
# Get from: https://s01.oss.sonatype.org/ (create account & get API token)
OSSRH_USERNAME=your_ossrh_username
OSSRH_PASSWORD=your_ossrh_api_token

# GPG Signing Key (for artifact signing)
# Get from: gpg --export-secret-keys --armor | base64
# Or generate: gpg --full-generate-key
SIGNING_KEY=base64_encoded_gpg_private_key
SIGNING_PASSWORD=your_signing_key_password
